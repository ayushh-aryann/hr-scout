# ─────────────────────────────────────────────
#  HR Scout — Environment Variables
# ─────────────────────────────────────────────
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── LLM Provider ──────────────────────────────
# Choose: anthropic | openai | local
# "local" uses heuristic scoring (no API key required)
LLM_PROVIDER=anthropic

# Anthropic API Key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# OpenAI API Key (optional fallback)
OPENAI_API_KEY=sk-your-openai-key-here

# Model identifiers
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o-mini

# ── API Security ───────────────────────────────
# Used to protect override/admin endpoints
API_SECRET_KEY=change-me-to-a-strong-random-secret

# ── Server ────────────────────────────────────
HOST=127.0.0.1
PORT=8000
DEBUG=false

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO
# Set to true to mask PII in logs
MASK_PII_IN_LOGS=true

# ── Storage ───────────────────────────────────
# Directory for session data and audit logs
STORAGE_DIR=./outputs
